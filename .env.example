# --- Database ---
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/immersia

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
ADMIN_SEED_EMAIL=admin@immersia.ng
ADMIN_SEED_PASSWORD=change-on-first-login
ADMIN_SEED_NAME=Mr Seun

# --- Paystack ---
# From: Paystack Dashboard → Settings → API Keys & Webhooks.
# The secret key also verifies webhook signatures. Use sk_test_… in dev, sk_live_… in prod.
PAYSTACK_SECRET_KEY=<your-paystack-secret-key>
PAYSTACK_PUBLIC_KEY=<your-paystack-public-key>

# --- Pricing (single source of truth: lib/pricing.ts) ---
# All amounts in KOBO (₦1 = 100 kobo). Leave unset to use the defaults shown here.
# These drive what campers are SHOWN and CHARGED, so keep them accurate.
PRICE_EARLY_BIRD_KOBO=15000000        # ₦150,000 boot camp fee before the early-bird cutoff (in-person)
PRICE_REGULAR_KOBO=15000000           # ₦150,000 boot camp fee after the cutoff (in-person)
PRICE_ONLINE_KOBO=5000000             # ₦50,000 flat fee for the online track (fully remote)
PRICE_ONLINE_EMBEDDED_KOBO=3500000    # +₦35,000 optional online Embedded Systems elective (kit + delivery, all-in)
PRICE_LAPTOP_RENTAL_KOBO=2000000      # +₦20,000 optional laptop rental (in-person only)
PRICE_ROBOTICS_ELECTIVE_KOBO=2500000  # +₦25,000 optional in-person Robotics & Embedded Systems elective
PRICE_DEPOSIT_KOBO=7500000            # ₦75,000 instalment deposit quoted in terms/FAQ (display only)
# Early-bird cutoff (ISO 8601). A PAST date means early-bird is closed (regular pricing +
# no banner); a FUTURE date opens the ₦150k early-bird window until then. The admin "Cohort
# dates" setting overrides this at runtime. Early-bird is currently closed.
EARLY_BIRD_CUTOFF=2026-07-03T23:59:59.000Z
# Limited-time discounts are managed as promo codes in the admin panel (/admin/promos) —
# no env var needed.

# --- SMTP ---
# Fill these in with your mail provider's SMTP details. If you are using Gmail,
# the password should be a 16-character App Password, not your normal login.
# Google only shows that App Password once, so if you lose it you generate a new one.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail-or-workspace-address@immersia.ng
SMTP_PASS=
SMTP_FROM="Immersia Boot Camp <noreply@immersia.ng>"
ADMIN_ALERT_EMAIL=registrations@immersia.ng

# --- App ---
APP_URL=http://localhost:3000
# Public canonical site URL — used for SEO metadata, sitemap, robots and OG tags.
NEXT_PUBLIC_SITE_URL=https://www.aixrbootcamp.com
NODE_ENV=development
