# --- Database ---
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/immersia

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
ADMIN_SEED_EMAIL=admin@immersia.ng
ADMIN_SEED_PASSWORD=change-on-first-login
ADMIN_SEED_NAME=Mr Seun

# --- Monnify ---
# Get all three from: Monnify Dashboard → Settings → API Keys & Webhooks.
# The secret key doubles as the webhook signature secret.
# Sandbox: https://sandbox.monnify.com   |   Live: https://api.monnify.com
MONNIFY_API_KEY=MK_TEST_xxxxxxxxxxxx
MONNIFY_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
MONNIFY_CONTRACT_CODE=xxxxxxxxxx
MONNIFY_BASE_URL=https://sandbox.monnify.com

# --- SMTP ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=postmaster@immersia.ng
SMTP_PASS=
SMTP_FROM="Immersia Boot Camp <noreply@immersia.ng>"
ADMIN_ALERT_EMAIL=registrations@immersia.ng

# --- App ---
APP_URL=http://localhost:3000
NODE_ENV=development
